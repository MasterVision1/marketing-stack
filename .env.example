# ============================================
# Marketing Stack Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to source control
# ============================================

# ---- General ----
DOMAIN=localhost
PROTOCOL=http

# ---- Postgres (shared) ----
POSTGRES_USER=marketing_stack
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_DB=marketing_stack

# ---- n8n ----
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N
N8N_ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_32CHARS
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=n8n
N8N_DB_POSTGRESDB_USER=marketing_stack
N8N_DB_POSTGRESDB_PASSWORD=CHANGE_ME_POSTGRES
N8N_WEBHOOK_URL=http://localhost:5678/

# ---- Mautic ----
MAUTIC_PORT=8080
MAUTIC_DB_HOST=postgres
MAUTIC_DB_PORT=5432
MAUTIC_DB_NAME=mautic
MAUTIC_DB_USER=marketing_stack
MAUTIC_DB_PASSWORD=CHANGE_ME_POSTGRES
MAUTIC_ADMIN_EMAIL=admin@example.com
MAUTIC_ADMIN_PASSWORD=CHANGE_ME_MAUTIC
MAUTIC_SECRET_KEY=CHANGE_ME_MAUTIC_SECRET
MAUTIC_URL=http://localhost:8080

# ---- Buffer (GraphQL API — beta) ----
# Get your token at: https://publish.buffer.com/settings/api
BUFFER_ACCESS_TOKEN=CHANGE_ME_BUFFER_TOKEN
BUFFER_API_URL=https://api.buffer.com

# ---- Dynamics 365 / Dataverse ----
# Your Dataverse org URL (from Power Platform admin center)
DYNAMICS365_URL=CHANGE_ME_DYNAMICS365_URL
DYNAMICS365_SOLUTION=ConsultingOpsCore
# Auth: az login first, then scripts use az account get-access-token

# ---- Redis (Mautic queue) ----
REDIS_PORT=6379
